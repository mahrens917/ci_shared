{
  "repo_context": "Shared CI tooling for Zeus, Monitor, AWS, common, signals, analytics, and service repositories (price_feeds, deribit, kalshi, pdf, poly, polyus, tracker, weather).",
  "protected_path_prefixes": [
    "ci_tools/",
    "scripts/ci.sh",
    "ci_shared.mk",
    "shared-tool-config.toml"
  ],
  "consuming_repositories": [
    {
      "name": "zeus",
      "path": "~/projects/zeus"
    },
    {
      "name": "monitor",
      "path": "~/projects/monitor"
    },
    {
      "name": "aws",
      "path": "~/projects/aws"
    },
    {
      "name": "common",
      "path": "~/projects/common"
    },
    {
      "name": "signals",
      "path": "~/projects/signals"
    },
    {
      "name": "analytics",
      "path": "~/projects/analytics"
    },
    {
      "name": "price_feeds",
      "path": "~/projects/price_feeds"
    },
    {
      "name": "deribit",
      "path": "~/projects/deribit"
    },
    {
      "name": "kalshi",
      "path": "~/projects/kalshi"
    },
    {
      "name": "pdf",
      "path": "~/projects/pdf"
    },
    {
      "name": "tracker",
      "path": "~/projects/tracker"
    },
    {
      "name": "weather",
      "path": "~/projects/weather"
    },
    {
      "name": "poly",
      "path": "~/projects/poly"
    },
    {
      "name": "textual-term",
      "path": "~/projects/textual-term"
    },
    {
      "name": "polyus",
      "path": "~/projects/polyus"
    }
  ],
  "commit_message": {
    "model": "claude-sonnet-4-6",
    "reasoning": "medium",
    "chunk_line_limit": 2000,
    "max_chunks": 12
  }
}
